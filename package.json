{
    "name": "iridium",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "react-router build",
        "dev": "react-router dev",
        "start": "react-router-serve ./build/server/index.js",
        "typecheck": "react-router typegen && tsc",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "validate": "bun run typecheck && bun run lint && bun run format:check",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "db:generate": "bunx --bun prisma generate",
        "db:migrate": "bunx --bun prisma migrate dev",
        "db:push": "bunx --bun prisma db push",
        "db:reset": "bunx --bun prisma migrate reset",
        "db:seed": "bunx --bun prisma db seed",
        "db:studio": "bunx --bun prisma studio",
        "db:fresh": "bun run db:reset -- --force && bun run db:seed"
    },
    "dependencies": {
        "@ai-sdk/react": "^3.0.136",
        "@hookform/resolvers": "^5.2.2",
        "@json-render/core": "^0.8.0",
        "@json-render/react": "^0.8.0",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@react-router/node": "7.12.0",
        "@react-router/serve": "7.12.0",
        "@tailwindcss/typography": "^0.5.19",
        "@voltagent/core": "^2.6.12",
        "@voltagent/postgres": "^2.1.2",
        "ai": "^6.0.134",
        "better-auth": "^1.5.6",
        "cva": "^1.0.0-beta.4",
        "dotenv": "^17.3.1",
        "isbot": "^5.1.36",
        "lucide-react": "^0.575.0",
        "pg": "^8.20.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.0",
        "react-markdown": "^10.1.0",
        "react-router": "7.12.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "tiny-invariant": "^1.3.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@react-router/dev": "7.12.0",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^22.19.15",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "daisyui": "^5.5.19",
        "eslint": "^10.1.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "prisma": "^7.5.0",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.1.1"
    }
}
