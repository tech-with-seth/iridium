{
    "name": "iridium",
    "private": true,
    "type": "module",
    "scripts": {
        "setup": "bun tools/init.ts",
        "build": "react-router build",
        "dev": "react-router dev",
        "start": "react-router-serve ./build/server/index.js",
        "typecheck": "react-router typegen && tsc",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "validate": "bun run typecheck && bun run lint && bun run format:check",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "db:generate": "bunx --bun prisma generate",
        "db:migrate": "bunx --bun prisma migrate dev",
        "db:push": "bunx --bun prisma db push",
        "db:reset": "bunx --bun prisma migrate reset",
        "db:seed": "bunx --bun prisma db seed",
        "db:studio": "bunx --bun prisma studio",
        "db:fresh": "bun run db:reset -- --force && bun run db:seed",
        "docker:up": "docker compose -f docker-compose.dev.yml up -d",
        "docker:down": "docker compose -f docker-compose.dev.yml down",
        "docker:nuke": "docker compose -f docker-compose.dev.yml down -v",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css,yml,yaml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@ai-sdk/react": "^3.0.191",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.8",
        "@react-router/node": "7.14.2",
        "@react-router/serve": "7.14.2",
        "@tailwindcss/typography": "^0.5.19",
        "@voltagent/core": "^2.7.4",
        "@voltagent/postgres": "^2.1.2",
        "ai": "^6.0.189",
        "better-auth": "^1.6.11",
        "cva": "^1.0.0-beta.4",
        "dotenv": "^17.4.2",
        "isbot": "^5.1.40",
        "lucide-react": "^1.16.0",
        "pg": "^8.21.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-hook-form": "^7.76.0",
        "react-markdown": "^10.1.0",
        "react-router": "7.14.2",
        "resend": "^6.12.4",
        "tailwind-merge": "^3.6.0",
        "tiny-invariant": "^1.3.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@inquirer/prompts": "^8.5.2",
        "@playwright/test": "^1.60.0",
        "@react-router/dev": "7.14.2",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.1",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "daisyui": "^5.5.20",
        "eslint": "^10.4.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.7.4",
        "prisma": "^7.8.0",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vite": "^7.3.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.7"
    }
}
