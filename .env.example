# Database — PostgreSQL connection string
# If using docker-compose.dev.yml: postgresql://postgres:postgres@localhost:5432/iridium
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iridium"

# VoltAgent Memory — separate PostgreSQL instance for AI agent memory
# If using docker-compose.dev.yml: postgresql://postgres:postgres@localhost:5433/voltagent
VOLTAGENT_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/voltagent"

# Better Auth — session encryption secret (min 32 chars)
# Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Better Auth — base URL (must match where the app is running)
BETTER_AUTH_BASE_URL="http://localhost:5173"

# Vite-exposed copy for the client-side auth SDK
VITE_BETTER_AUTH_BASE_URL="http://localhost:5173"

# Anthropic — required for AI chat features
ANTHROPIC_API_KEY=""
